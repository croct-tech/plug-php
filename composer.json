{
  "name": "croct/plug-php",
  "description": "A brief description about the project.",
  "license": "proprietary",
  "type": "library",
  "keywords": [
    "croct",
    "related",
    "keyword"
  ],
  "authors": [
    {
      "name": "Croct",
      "email": "lib+project-php@croct.com",
      "homepage": "https://croct.com"
    }
  ],
  "homepage": "https://github.com/croct-tech/project-php",
  "require": {
    "php": "^8.0"
  },
  "require-dev": {
    "croct/coding-standard": "^0.4",
    "ergebnis/composer-normalize": "^2.28",
    "phpstan/phpstan": "^1.8",
    "phpstan/phpstan-deprecation-rules": "^1.0",
    "phpstan/phpstan-phpunit": "^1.1",
    "phpstan/phpstan-strict-rules": "^1.4",
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://croct.repo.repman.io",
      "secure-http": true
    }
  ],
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Croct\\Project\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Croct\\Project\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "phpstan/extension-installer": false
    }
  },
  "scripts": {
    "test": [
      "composer validate",
      "composer normalize --dry-run",
      "mkdir -p .cache",
      "phpcs",
      "phpstan analyse",
      "phpunit"
    ]
  }
}
