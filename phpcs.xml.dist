<?xml version="1.0"?>
<ruleset
        name="PHPCS Coding Standard for croct/coding-standard"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="../../../vendor/squizlabs/php_codesniffer/phpcs.xsd"
>
    <config name="installed_paths" value="../../croct/coding-standard/src,../../slevomat/coding-standard"/>

    <arg name="cache" value=".cache/phpcs.cache.json"/>
    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="colors" />
    <arg value="p"/>

    <rule ref="Croct">
        <!-- False positives for multiline arrays with closure as value, remove once fixed: -->
        <exclude name="Squiz.Arrays.ArrayDeclaration.ValueNoNewline"/>
    </rule>

    <!--
        ApiKey::parse() keeps #[\SensitiveParameter] inline on a single-line signature, which the
        single-line method-signature rule requires but this sniff forbids; exclude it for this file.
    -->
    <rule ref="SlevomatCodingStandard.Attributes.AttributeAndTargetSpacing">
        <exclude-pattern>src/ApiKey.php</exclude-pattern>
    </rule>

    <file>src</file>
    <file>tests</file>
</ruleset>
