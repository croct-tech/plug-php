parameters:
    stubFiles:
        - src/FetchResponse.php
        - src/FetchOptions.php
        - stubs/Components.php
        - stubs/Slots.php
        - stubs/ComponentMap.php
        - stubs/SlotMap.php

services:
    -
        class: Croct\Plug\PhpStan\ContentStubFilesExtension
        arguments:
            workingDirectory: %currentWorkingDirectory%
        tags:
            - phpstan.stubFilesExtension
